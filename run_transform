#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SH_SCRIPT="$ROOT_DIR/run_transform.sh"
PS_SCRIPT="$ROOT_DIR/run_transform.ps1"

is_windows_env() {
  case "${OS:-}" in
    Windows_NT) return 0 ;;
  esac

  case "$(uname -s 2>/dev/null || echo unknown)" in
    MINGW*|MSYS*|CYGWIN*) return 0 ;;
  esac

  return 1
}

if is_windows_env; then
  if command -v pwsh >/dev/null 2>&1; then
    exec pwsh -NoProfile -File "$PS_SCRIPT" "$@"
  fi

  if command -v powershell >/dev/null 2>&1; then
    exec powershell -NoProfile -ExecutionPolicy Bypass -File "$PS_SCRIPT" "$@"
  fi

  echo "Error: entorno Windows detectado, pero no se encontro 'pwsh' ni 'powershell' en PATH."
  exit 1
fi

exec "$SH_SCRIPT" "$@"